# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub!

# ===========================
# Razorpay Configuration
# ===========================
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ===========================
# Email Configuration (Optional)
# ===========================
# For sending OTP emails
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ===========================
# Flask Configuration
# ===========================
# Generate a random secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_make_it_long_and_random

# Environment (production or development)
FLASK_ENV=production

# ===========================
# Database Configuration
# ===========================
# For PythonAnywhere, use: sqlite:///database/school.db
# For local development: database/school.db
DATABASE_URL=sqlite:///database/school.db

# ===========================
# Redis Configuration (Optional)
# ===========================
# Leave empty for in-memory OTP storage
REDIS_URL=

# ===========================
# Session Configuration
# ===========================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
